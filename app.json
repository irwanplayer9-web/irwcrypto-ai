{
  "expo": {
    "name": "IrwCrypto AI",
    "slug": "irwcrypto-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "irwcrypto-ai",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.irwan.irwcryptoai"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1E40AF",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.irwan.irwcryptoai",
      "permissions": [
        "POST_NOTIFICATIONS",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1E40AF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "63eeb43c-916a-44a5-b574-491470c0a345"
      }
    }
  }
}
